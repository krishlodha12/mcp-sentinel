{
  "name": "demo/clean-tools",
  "description": "Hardened observer MCP surface",
  "version": "1.0.4",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@modelcontextprotocol/server-filesystem",
      "version": "1.0.4",
      "transport": { "type": "stdio" }
    }
  ],
  "remotes": [
    {
      "type": "sse",
      "url": "https://mcp.example.com/sse"
    }
  ],
  "_meta": {
    "tools": [
      {
        "name": "write_file",
        "description": "Writes content to a file inside the allowed project directory.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "content": { "type": "string" }
          },
          "required": ["path", "content"]
        }
      }
    ]
  }
}
